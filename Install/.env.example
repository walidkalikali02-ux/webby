APP_NAME=Webby
APP_ENV=production
APP_KEY=base64:cGxhY2Vob2xkZXJrZXlmb3J3ZWJieWluc3RhbGxlcjE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Demo Mode Configuration (only used when APP_DEMO=true AND APP_ENV=local)
APP_DEMO=
APP_DEMO_AI_KEY=
APP_DEMO_PUSHER_APPID=
APP_DEMO_PUSHER_KEY=
APP_DEMO_PUSHER_SECRET=
APP_DEMO_PUSHER_CLUSTER=
APP_DEMO_SMTP_HOST=
APP_DEMO_SMTP_PORT=587
APP_DEMO_SMTP_USERNAME=
APP_DEMO_SMTP_PASSWORD=
APP_DEMO_SMTP_ENCRYPTION=tls
APP_DEMO_SMTP_FROM_ADDRESS=
APP_DEMO_SMTP_FROM_NAME=
APP_DEMO_CODE=

# Sentry Error Reporting Endpoint
APP_SENTRY=https://sentry.titansys.dev

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"

# NOTE: App configurations (Pusher/Reverb, Firebase, social login, email, builders, etc.)
# are managed via Admin Panel (/admin/*), not .env
